# Antigravity session variables consumed by cmd/antigravity-bridge.
# The bridge auto-loads this file (walking up parent dirs) when these vars
# are not already set in the shell. Easiest correct setup: launch the bridge
# from Antigravity's integrated terminal, which injects fresh values.
# Copy this file to .env.antigravity and fill in the current session values.
ANTIGRAVITY_CSRF_TOKEN=<from Antigravity integrated terminal>
ANTIGRAVITY_LS_ADDRESS=localhost:<language-server-port>
ANTIGRAVITY_PROJECT_ID=<antigravity-project-id>
