# Kaimi Environment Configuration
# Copy this file to .env and fill in your actual values

# SAM.gov API Key
# Get yours at: https://open.gsa.gov/api/get-key/
SAM_API_KEY=your-sam-api-key-here

# Google AI Studio API Key (for Gemini agent platform)
# Get yours at: https://aistudio.google.com/apikey
# Project name: AI-Agent-Team
GOOGLE_AI_STUDIO_API_KEY=your-ai-studio-api-key-here

# Hunter Configuration (optional - can also use command-line flags)
# MODE=cached
# NAICS_CODES=541512,541519
# STORE_PATH=./queue
